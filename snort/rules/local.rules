
# WebGoat SQL Injection Detection
alert tcp any any -> any 8080
(
    msg:"SQL Injection - OR 1=1 Pattern";
    flow:to_server,established;
    content:"' or '1'='1", nocase;
    sid:1000001;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

alert tcp any any -> any 8080
(
    msg:"SQL Injection - URL Encoded OR 1=1";
    content:"%27%20or%20%271%27%3d%271", nocase;
    sid:1000003;
    rev:1;
    priority:1;
    classtype:web-application-attack;
)

alert tcp any any -> any 8080
(
    msg:"SQL Injection - UNION SELECT";
    flow:to_server,established;
    content:"UNION SELECT", nocase;
    sid:1000002;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

# XSS Detection
alert tcp any any -> any 8080
(
    msg:"XSS - Script Tag Injection";
    flow:to_server,established;
    content:"<script", nocase;
    sid:1000004;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

alert tcp any any -> any 8080
(
    msg:"XSS - JavaScript Protocol";
    flow:to_server,established;
    content:"javascript:", nocase;
    sid:1000005;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

# Path Traversal
alert tcp any any -> any 8080
(
    msg:"Path Traversal - Double Dot";
    flow:to_server,established;
    content:"../";
    sid:1000006;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

alert tcp any any -> any 8080
(
    msg:"Path Traversal - Passwd File";
    flow:to_server,established;
    content:"/etc/passwd", nocase;
    sid:1000007;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

# Command Injection
alert tcp any any -> any 8080
(
    msg:"Command Injection - Pipe Character";
    flow:to_server,established;
    content:"|7C| ls", nocase;
    sid:1000008;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

alert tcp any any -> any 8080
(
    msg:"Command Injection - Semicolon";
    flow:to_server,established;
    content:"; ls", nocase;
    sid:1000009;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

# Authentication Bypass
alert tcp any any -> any 8080
(
    msg:"Auth Bypass - Admin Probe";
    flow:to_server,established;
    content:"admin'--", nocase;
    sid:1000010;
    rev:2;
    priority:1;
    classtype:attempted-admin;
)

# Reconnaissance
alert tcp any any -> any 8080
(
    msg:"Recon - SQLMap Detected";
    flow:to_server,established;
    content:"User-Agent|3A| sqlmap", nocase;
    sid:1000011;
    rev:2;
    priority:2;
    classtype:attempted-recon;
)

alert tcp any any -> any 8080
(
    msg:"Recon - Nikto Detected";
    flow:to_server,established;
    content:"User-Agent|3A| Nikto", nocase;
    sid:1000012;
    rev:2;
    priority:2;
    classtype:attempted-recon;
)

# Large Payload
alert tcp any any -> any 8080
(
    msg:"Large Payload - Possible Attack";
    flow:to_server,established;
    content:"POST ", nocase;
    dsize:>2048;
    sid:1000013;
    rev:2;
    priority:2;
    classtype:web-application-attack;
)

# WebGoat Specific Lessons
alert tcp any any -> any 8080
(
    msg:"WebGoat - SQL Injection Lesson";
    content:"/WebGoat/SqlInjection", nocase;
    sid:1000014;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

alert tcp any any -> any 8080
(
    msg:"WebGoat - XSS Lesson";
    flow:to_server,established;
    content:"/WebGoat/cross-site-scripting", nocase;
    sid:1000015;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

alert tcp any any -> any 8080
(
    msg:"WebGoat - Path Traversal Lesson";
    flow:to_server,established;
    content:"/WebGoat/PathTraversal", nocase;
    sid:1000016;
    rev:2;
    priority:1;
    classtype:web-application-attack;
)

