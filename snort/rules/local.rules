# Brute Force Detection Pattern
alert tcp any any -> any 8080
(
    msg:"Multiple Login Attempts";
    flow:to_server,established;
    content:"/login", nocase;
    sid:1001002;
    rev:2;
    priority:2;
    classtype:attempted-recon;
)
